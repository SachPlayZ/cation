# Canton JSON Ledger API
LEDGER_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
# Mode: "oidc" | "token" | "external-party"
LEDGER_AUTH_MODE=token

# Static bearer token (when LEDGER_AUTH_MODE=token)
LEDGER_STATIC_TOKEN=<bearer-token-from-validator>

# OIDC client credentials (when LEDGER_AUTH_MODE=oidc)
LEDGER_OIDC_ISSUER=https://your-oidc-issuer.example.com
LEDGER_OIDC_CLIENT_ID=your-client-id
LEDGER_OIDC_CLIENT_SECRET=your-client-secret

# External-party signing key (when LEDGER_AUTH_MODE=external-party — stub only)
CANTON_PRIVATE_KEY=<pem-or-base64-private-key>

# Daml package ID (optional — if set, overrides #cation name-reference format)
# Get this from: daml inspect daml/.daml/dist/cation-1.0.0.dar | grep "Package ID"
PACKAGE_ID=

# Canton party IDs (from validator party allocation)
PARTY_CFO=cfo::1220...
PARTY_AGENT=agent::1220...
PARTY_COMPLIANCE=compliance::1220...
PARTY_OPS=ops-account::1220...
PARTY_RESERVE=reserve-account::1220...
# Optional: override recipient party (defaults to PARTY_OPS)
PARTY_RECIPIENT=

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cation?retryWrites=true&w=majority

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Groq API key
GROQ_API_KEY=gsk_...
